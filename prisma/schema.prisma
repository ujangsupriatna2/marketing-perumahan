generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Mitra {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  subdomain   String   @unique
  logo        String   @default("")
  description String   @default("")
  address     String   @default("")
  phone       String   @default("")
  email       String   @default("")
  website     String   @default("")
  primaryColor String  @default("#dc2626")
  accentColor String   @default("#f59e0b")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  admins       Admin[]
  properties   Property[]
  blogPosts    BlogPost[]
  testimonials Testimonial[]
  galleryItems GalleryItem[]
  banks        Bank[]
  settings     Setting[]
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  avatar    String?
  mitraId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mitra Mitra? @relation(fields: [mitraId], references: [id], onDelete: SetNull)
}

model Property {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  type             String
  category         String   @default("inden")
  price            Float
  location         String   @default("Bandung Raya Residence")
  bedrooms         Int      @default(2)
  bathrooms        Int      @default(1)
  landArea         Float    @default(0)
  buildingArea     Float    @default(0)
  status           String   @default("available")
  description      String   @default("")
  features         String   @default("[]")
  images           String   @default("[]")
  tag              String   @default("")
  installment      String   @default("")
  financingTypes   String   @default("[\"syariah\",\"kpr\"]")
  dpOptions        String   @default("[30,35,40,45,50]")
  tenorOptions     String   @default("[1,2,3,4,5]")
  installments     String   @default("{}")
  syariahMargin    Float    @default(15)
  kprDpOptions     String   @default("[0,10,15,20,25,30]")
  kprTenorOptions  String   @default("[5,10,15,20,25]")
  kprInstallments  String   @default("{}")
  isFeatured       Boolean  @default(false)
  mitraId          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mitra Mitra? @relation(fields: [mitraId], references: [id], onDelete: SetNull)
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String   @default("")
  content   String   @default("")
  category  String
  author    String   @default("Admin BRR")
  image     String   @default("")
  published Boolean  @default(false)
  readTime  String   @default("5 menit")
  views     Int      @default(0)
  mitraId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mitra Mitra? @relation(fields: [mitraId], references: [id], onDelete: SetNull)
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  text      String
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  mitraId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mitra Mitra? @relation(fields: [mitraId], references: [id], onDelete: SetNull)
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  category    String
  image       String
  description String   @default("")
  sortOrder   Int      @default(0)
  mitraId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mitra Mitra? @relation(fields: [mitraId], references: [id], onDelete: SetNull)
}

model Bank {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  image       String   @default("")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  mitraId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mitra Mitra? @relation(fields: [mitraId], references: [id], onDelete: SetNull)
}

model Setting {
  id        String   @id @default(cuid())
  key       String
  value     String
  label     String   @default("")
  group     String   @default("general")
  mitraId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mitra Mitra? @relation(fields: [mitraId], references: [id], onDelete: SetNull)

  @@unique([key, mitraId])
}
